# Shared local development settings for MindMap Care.
# Copy this file to .env and keep real secrets out of git.

COMPOSE_PROJECT_NAME=mindmap-care
MINDMAP_ENVIRONMENT=local

# Host ports exposed by Docker Compose.
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Browser-facing service URLs used by local tooling and the frontend.
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=MindMap Care
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend runtime settings.
MINDMAP_APP_NAME=MindMap Care API
MINDMAP_APP_VERSION=0.1.0
MINDMAP_SERVICE_NAME=mindmap-care-backend
MINDMAP_API_V1_PREFIX=/api/v1
MINDMAP_CORS_ALLOW_ORIGINS=http://localhost:3000
MINDMAP_LOG_LEVEL=INFO
MINDMAP_REQUEST_TIMEOUT_SECONDS=30
