# Backend-only settings.
# Copy to .env for local development.

MINDMAP_ENVIRONMENT=local
MINDMAP_APP_NAME=MindMap Care API
MINDMAP_APP_VERSION=0.1.0
MINDMAP_SERVICE_NAME=mindmap-care-backend
MINDMAP_API_HOST=0.0.0.0
MINDMAP_API_PORT=8000
MINDMAP_API_V1_PREFIX=/api/v1
MINDMAP_CORS_ALLOW_ORIGINS=http://localhost:3000
MINDMAP_LOG_LEVEL=INFO
MINDMAP_REQUEST_TIMEOUT_SECONDS=30
